# ─────────────────────────────────────────────────────────────────
# n8n Environment Configuration — TEMPLATE
# Usage: cp .env.example .env   then fill in every value
# NEVER commit .env to git (it contains your passwords)
# ─────────────────────────────────────────────────────────────────

# Your domain name (e.g. n8n.yourdomain.com)
N8N_HOST=

# Full webhook URL — must end with /
# Example: https://n8n.yourdomain.com/
WEBHOOK_URL=

# https for production with SSL, http for local testing only
N8N_PROTOCOL=https

# Basic auth — protect the n8n editor from public access
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=Asia/Kolkata

# Optional: email for Let's Encrypt renewal notifications (used by ssl.sh)
# CERTBOT_EMAIL=you@yourdomain.com

# ─────────────────────────────────────────────────────────────────
# OPTIONAL: Postgres backend (leave commented for default SQLite)
# Uncomment the db service in docker-compose.yml to use these.
# ─────────────────────────────────────────────────────────────────
# POSTGRES_DB=n8n
# POSTGRES_USER=n8n
# POSTGRES_PASSWORD=
